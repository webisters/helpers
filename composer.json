{
    "name": "webisters/helpers",
    "description": "Webisters Helpers Library",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "helpers",
        "array-simple",
        "files",
        "isolation"
    ],
    "authors": [
        {
            "name": "Hafiz Muhammad Moaz",
            "email": "hafizmoazkhalid@gmail.com",
            "homepage": "https://github.com/HafizMMoaz"
        }
    ],
    "homepage": "https://webisters.com/packages/helpers",
    "support": {
        "email": "support@webisters.com",
        "issues": "https://github.com/webisters/helpers/issues",
        "forum": "https://github.com/webisters/forum",
        "source": "https://github.com/webisters/helpers",
        "docs": "https://webisters.com"
    },
    "funding": [
        {
            "type": "Webisters Sponsor",
            "url": "https://webisters.com/sponsor"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "webisters/coding-standard": "*",
        "jetbrains/phpstorm-attributes": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Framework\\Helpers\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Helpers\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}


